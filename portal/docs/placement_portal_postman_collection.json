{
  "info": {
    "name": "Placement & Internship Management Portal",
    "description": "Complete API documentation for the Placement & Internship Management Portal built with Spring Boot and MySQL.\n\nBase URL: http://localhost:8080\n\nFeatures covered:\n- Company Registration & Management\n- Job & Internship Postings with Branch/CGPA Filters\n- Student Registration & Applications\n- Eligibility Check\n- Shortlisting (Single & Bulk)\n- Multi-round Interview Scheduling\n- Placement Reports\n- Excel Export",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Companies",
      "description": "APIs for company registration and management",
      "item": [
        {
          "name": "Register Company",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/companies", "host": ["{{baseUrl}}"], "path": ["api", "companies"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"TechCorp Solutions\",\n  \"domain\": \"Product\",\n  \"email\": \"hr@techcorp.com\",\n  \"location\": \"Hyderabad\",\n  \"description\": \"Leading product-based software company\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get All Companies",

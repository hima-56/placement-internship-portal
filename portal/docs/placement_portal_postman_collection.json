    {
      "name": "6. Interviews",
      "description": "APIs for scheduling and managing multi-round interviews",
      "item": [
        {
          "name": "Schedule Interview Round",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/interviews", "host": ["{{baseUrl}}"], "path": ["api", "interviews"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"applicationId\": 1,\n  \"scheduledAt\": \"2026-06-20T10:30:00\",\n  \"mode\": \"Online\",\n  \"feedback\": \"Round 1 - Technical screening\"\n}"
            }
          },
          "response": [],
          "_postman_notes": "Round number is auto-determined. Round 1 is assigned if no previous round exists. Next round is only allowed if previous round result is PASSED."
        },
        {
          "name": "Update Interview Result",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/interviews/1/result", "host": ["{{baseUrl}}"], "path": ["api", "interviews", "1", "result"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"result\": \"PASSED\",\n  \"feedback\": \"Excellent DSA skills, proceed to round 2\"\n}"
            }
          },
          "response": [],
          "_postman_notes": "result must be PASSED or FAILED. If FAILED, application is marked REJECTED automatically."
        },
        {
          "name": "Update Interview Result (FAILED)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/interviews/1/result", "host": ["{{baseUrl}}"], "path": ["api", "interviews", "1", "result"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"result\": \"FAILED\",\n  \"feedback\": \"Needs improvement in system design\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get Interviews For Student",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/interviews/student/1", "host": ["{{baseUrl}}"], "path": ["api", "interviews", "student", "1"] }
          },
          "response": [],
          "_postman_notes": "Student can view all their scheduled interviews across all applications and rounds."
        },
        {
          "name": "Get Interview Round History For Application",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/interviews/application/1", "host": ["{{baseUrl}}"], "path": ["api", "interviews", "application", "1"] }
          },
          "response": [],
          "_postman_notes": "Returns all rounds (round 1, round 2, etc.) for a specific application."
        }
      ]
